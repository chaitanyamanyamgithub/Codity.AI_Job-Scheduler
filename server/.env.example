DATABASE_URL=postgres://scheduler:scheduler_secret@localhost:5432/job_scheduler
JWT_SECRET=super_secret_jwt_key_change_in_production
PORT=3000
NODE_ENV=development

# Worker configuration
WORKER_POLL_INTERVAL_MS=500
WORKER_MAX_PARALLEL_JOBS=5
WORKER_NAME=worker-local
WORKER_SHARD_KEY=default
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKER_STALE_THRESHOLD_MS=30000
WORKER_SHUTDOWN_TIMEOUT_MS=30000

# Scheduler configuration
SCHEDULER_TICK_INTERVAL_MS=3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_READ_REQUESTS=120
RATE_LIMIT_MUTATION_REQUESTS=60

# Run migrations on API start
RUN_MIGRATIONS=true
